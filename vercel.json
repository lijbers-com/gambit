{
  "buildCommand": "npm run build && rm -rf public/storybook && npx storybook build -o public/storybook",
  "installCommand": "npm install",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/storybook",
      "destination": "/storybook/index.html"
    },
    {
      "source": "/storybook/:path*",
      "destination": "/storybook/:path*"
    }
  ]
}